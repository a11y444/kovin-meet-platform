// KOVIN Meet - Complete Multi-Tenant Video Conferencing Platform
// Prisma Schema with full RBAC and multi-tenant isolation

generator client {
  provider = "prisma-client-js"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// TENANT & WHITE-LABEL CONFIGURATION
// ============================================

model Tenant {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique // subdomain or custom domain identifier
  domain      String?  @unique // custom domain if configured
  
  // White-label branding
  logoUrl     String?
  faviconUrl  String?
  primaryColor    String   @default("#0066FF")
  secondaryColor  String   @default("#1A1A2E")
  accentColor     String   @default("#00D4AA")
  
  // Platform settings
  maxUsers        Int      @default(50)
  maxMeetings     Int      @default(100)
  maxRecordingHours Int    @default(10)
  features        Json     @default("{}")  // Feature flags per tenant
  
  // Contact & billing
  billingEmail    String?
  contactEmail    String?
  phone           String?
  address         String?
  
  // Status
  isActive    Boolean  @default(true)
  isPaid      Boolean  @default(false)
  plan        String   @default("free") // free, starter, pro, enterprise
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  users       User[]
  roles       Role[]
  meetings    Meeting[]
  events      Event[]
  calendars   Calendar[]
  emailTemplates EmailTemplate[]
  emailCampaigns EmailCampaign[]
  auditLogs   AuditLog[]
  invitations Invitation[]
  
  @@index([slug])
  @@index([domain])
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id            String    @id @default(cuid())
  email         String
  emailVerified DateTime?
  passwordHash  String?
  
  // Profile
  firstName     String?
  lastName      String?
  displayName   String?
  avatarUrl     String?
  phone         String?
  timezone      String    @default("UTC")
  locale        String    @default("en")
  
  // Multi-tenant
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Role-based access
  roleId        String
  role          Role      @relation(fields: [roleId], references: [id])
  
  // Status
  isActive      Boolean   @default(true)
  isSuperAdmin  Boolean   @default(false) // Platform-level super admin
  lastLoginAt   DateTime?
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  sessions          Session[]
  accounts          Account[]
  hostedMeetings    Meeting[]     @relation("MeetingHost")
  meetingParticipants MeetingParticipant[]
  recordings        Recording[]
  tickets           Ticket[]
  calendarEvents    CalendarEvent[] @relation("CalendarEventCreator")
  calendarAttendees CalendarAttendee[]
  auditLogs         AuditLog[]
  sentEmails        EmailLog[]
  
  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Invitation {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  roleId    String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id])
  
  expiresAt DateTime
  acceptedAt DateTime?
  
  createdAt DateTime @default(now())
  
  @@index([token])
  @@index([tenantId])
}

// ============================================
// ROLE-BASED ACCESS CONTROL (RBAC)
// ============================================

model Role {
  id          String   @id @default(cuid())
  name        String   // admin, moderator, presenter, attendee, etc.
  displayName String
  description String?
  
  // Multi-tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Permissions stored as JSON array
  permissions Json     @default("[]") // ["users:read", "users:write", "meetings:create", etc.]
  
  // System role (cannot be deleted)
  isSystem    Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  users       User[]
  invitations Invitation[]
  
  @@unique([name, tenantId])
  @@index([tenantId])
}

// ============================================
// MEETINGS & VIDEO CONFERENCING
// ============================================

model Meeting {
  id          String   @id @default(cuid())
  title       String
  description String?
  
  // Scheduling
  scheduledStart DateTime?
  scheduledEnd   DateTime?
  actualStart    DateTime?
  actualEnd      DateTime?
  duration       Int?     // in minutes
  
  // Access
  roomCode    String   @unique // Short code for joining
  password    String?  // Optional meeting password
  isPublic    Boolean  @default(false)
  
  // LiveKit integration
  livekitRoom String?  // LiveKit room name
  
  // Settings
  settings    Json     @default("{}") // maxParticipants, allowRecording, waitingRoom, etc.
  
  // Status
  status      MeetingStatus @default(SCHEDULED)
  
  // Multi-tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Host
  hostId      String
  host        User     @relation("MeetingHost", fields: [hostId], references: [id])
  
  // Calendar integration
  calendarEventId String? @unique
  calendarEvent   CalendarEvent? @relation(fields: [calendarEventId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  participants MeetingParticipant[]
  recordings   Recording[]
  chatMessages MeetingChat[]
  
  @@index([tenantId])
  @@index([roomCode])
  @@index([hostId])
  @@index([status])
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

model MeetingParticipant {
  id        String   @id @default(cuid())
  
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  
  // Guest participants (no account)
  guestName  String?
  guestEmail String?
  
  // Participation
  role       ParticipantRole @default(ATTENDEE)
  joinedAt   DateTime?
  leftAt     DateTime?
  duration   Int?     // minutes in meeting
  
  // Status
  isInWaitingRoom Boolean @default(false)
  isAdmitted      Boolean @default(false)
  
  createdAt DateTime @default(now())
  
  @@unique([meetingId, userId])
  @@index([meetingId])
  @@index([userId])
}

enum ParticipantRole {
  HOST
  CO_HOST
  PRESENTER
  ATTENDEE
}

model MeetingChat {
  id        String   @id @default(cuid())
  meetingId String
  meeting   Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  senderId  String?  // null for system messages
  senderName String
  message   String   @db.Text
  
  isPrivate Boolean  @default(false)
  recipientId String?
  
  createdAt DateTime @default(now())
  
  @@index([meetingId])
}

// ============================================
// RECORDINGS
// ============================================

model Recording {
  id          String   @id @default(cuid())
  
  meetingId   String
  meeting     Meeting  @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  
  // Storage
  fileName    String
  fileUrl     String
  fileSize    Int      // bytes
  duration    Int      // seconds
  mimeType    String   @default("video/webm")
  
  // Processing
  status      RecordingStatus @default(PROCESSING)
  thumbnailUrl String?
  
  // Access
  isPublic    Boolean  @default(false)
  password    String?
  expiresAt   DateTime?
  
  // Ownership
  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([meetingId])
  @@index([createdById])
}

enum RecordingStatus {
  PROCESSING
  READY
  FAILED
  DELETED
}

// ============================================
// EVENTS & TICKETING
// ============================================

model Event {
  id          String   @id @default(cuid())
  title       String
  slug        String
  description String?  @db.Text
  
  // Media
  coverImageUrl String?
  
  // Scheduling
  startDate   DateTime
  endDate     DateTime
  timezone    String   @default("UTC")
  
  // Location
  isOnline    Boolean  @default(true)
  meetingLink String?
  venue       String?
  address     String?
  
  // Capacity
  maxAttendees Int?
  
  // Status
  status      EventStatus @default(DRAFT)
  isPublic    Boolean     @default(false)
  
  // Multi-tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  ticketTypes TicketType[]
  tickets     Ticket[]
  
  @@unique([slug, tenantId])
  @@index([tenantId])
  @@index([status])
  @@index([startDate])
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
  COMPLETED
}

model TicketType {
  id          String   @id @default(cuid())
  
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  name        String   // VIP, General, Early Bird
  description String?
  price       Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  
  // Inventory
  quantity    Int?     // null = unlimited
  soldCount   Int      @default(0)
  
  // Availability
  salesStart  DateTime?
  salesEnd    DateTime?
  
  // Restrictions
  maxPerOrder Int      @default(10)
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  tickets     Ticket[]
  
  @@index([eventId])
}

model Ticket {
  id          String   @id @default(cuid())
  
  ticketTypeId String
  ticketType   TicketType @relation(fields: [ticketTypeId], references: [id])
  
  eventId     String
  event       Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  // Purchaser
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  // Guest purchase
  guestEmail  String?
  guestName   String?
  guestPhone  String?
  
  // Ticket details
  ticketCode  String   @unique // QR code data
  qrCodeUrl   String?
  
  // Payment
  paymentId   String?  // Stripe payment intent ID
  paidAmount  Decimal  @db.Decimal(10, 2)
  currency    String   @default("USD")
  paymentStatus PaymentStatus @default(PENDING)
  
  // Check-in
  isCheckedIn Boolean  @default(false)
  checkedInAt DateTime?
  
  // Status
  status      TicketStatus @default(ACTIVE)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([eventId])
  @@index([userId])
  @@index([ticketCode])
}

enum TicketStatus {
  ACTIVE
  USED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

// ============================================
// CALENDAR
// ============================================

model Calendar {
  id          String   @id @default(cuid())
  name        String
  description String?
  color       String   @default("#0066FF")
  
  // Multi-tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  isPublic    Boolean  @default(false)
  isDefault   Boolean  @default(false)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  events      CalendarEvent[]
  
  @@index([tenantId])
}

model CalendarEvent {
  id          String   @id @default(cuid())
  
  calendarId  String
  calendar    Calendar @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  
  title       String
  description String?  @db.Text
  location    String?
  
  // Timing
  startTime   DateTime
  endTime     DateTime
  isAllDay    Boolean  @default(false)
  timezone    String   @default("UTC")
  
  // Recurrence
  isRecurring Boolean  @default(false)
  recurrenceRule String? // iCal RRULE format
  
  // Meeting link
  meetingId   String?
  meeting     Meeting?
  
  // Creator
  createdById String
  createdBy   User     @relation("CalendarEventCreator", fields: [createdById], references: [id])
  
  // Status
  status      CalendarEventStatus @default(CONFIRMED)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  attendees   CalendarAttendee[]
  
  @@index([calendarId])
  @@index([startTime])
  @@index([createdById])
}

enum CalendarEventStatus {
  TENTATIVE
  CONFIRMED
  CANCELLED
}

model CalendarAttendee {
  id          String   @id @default(cuid())
  
  eventId     String
  event       CalendarEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  // Guest attendee
  guestEmail  String?
  guestName   String?
  
  // Response
  responseStatus AttendeeResponse @default(NEEDS_ACTION)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

enum AttendeeResponse {
  NEEDS_ACTION
  ACCEPTED
  DECLINED
  TENTATIVE
}

// ============================================
// EMAIL SYSTEM
// ============================================

model EmailTemplate {
  id          String   @id @default(cuid())
  
  // Multi-tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  subject     String
  htmlContent String   @db.Text
  textContent String?  @db.Text
  
  // Variables available in template
  variables   Json     @default("[]") // ["firstName", "eventName", etc.]
  
  // Type
  type        EmailTemplateType @default(CUSTOM)
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  campaigns   EmailCampaign[]
  
  @@unique([name, tenantId])
  @@index([tenantId])
}

enum EmailTemplateType {
  WELCOME
  MEETING_INVITE
  MEETING_REMINDER
  EVENT_TICKET
  PASSWORD_RESET
  CUSTOM
}

model EmailCampaign {
  id          String   @id @default(cuid())
  
  // Multi-tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  name        String
  subject     String
  
  templateId  String?
  template    EmailTemplate? @relation(fields: [templateId], references: [id])
  
  // Content (if not using template)
  htmlContent String?  @db.Text
  
  // Targeting
  recipientFilter Json @default("{}") // Filter criteria for recipients
  
  // Scheduling
  scheduledAt DateTime?
  sentAt      DateTime?
  
  // Stats
  totalRecipients Int @default(0)
  sentCount       Int @default(0)
  openCount       Int @default(0)
  clickCount      Int @default(0)
  
  // Status
  status      EmailCampaignStatus @default(DRAFT)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  logs        EmailLog[]
  
  @@index([tenantId])
  @@index([status])
}

enum EmailCampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

model EmailLog {
  id          String   @id @default(cuid())
  
  campaignId  String?
  campaign    EmailCampaign? @relation(fields: [campaignId], references: [id])
  
  recipientId String
  recipient   User     @relation(fields: [recipientId], references: [id])
  
  email       String
  subject     String
  
  // Tracking
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  bouncedAt   DateTime?
  
  // Status
  status      EmailLogStatus @default(PENDING)
  errorMessage String?
  
  createdAt   DateTime @default(now())
  
  @@index([campaignId])
  @@index([recipientId])
  @@index([status])
}

enum EmailLogStatus {
  PENDING
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  FAILED
}

// ============================================
// AUDIT LOG
// ============================================

model AuditLog {
  id          String   @id @default(cuid())
  
  // Multi-tenant
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  
  // Actor
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  // Action
  action      String   // CREATE, UPDATE, DELETE, LOGIN, etc.
  entityType  String   // User, Meeting, Event, etc.
  entityId    String?
  
  // Details
  description String?
  metadata    Json     @default("{}") // Additional context
  
  // Request info
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([tenantId])
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
}
